# DataStory AI - Environment Variables
# Copy this file to .env and fill in your values.

# Optional: OpenRouter API key for AI explanations and report generation.
OPENROUTER_API_KEY=

# Optional: SQLite database path. In production, point this at persistent storage.
DATASTORY_DB=datastory.db

# Optional: comma-separated frontend origins allowed by the API.
# Use your deployed frontend URL in production.
CORS_ORIGINS=http://127.0.0.1:8501,http://localhost:8501
